=${makeDragHandler(\"right\")}></div>\n          `;\n        })", "source_file": "Agent Team version3\\control-ui\\src\\ui\\views\\usage-render-details.ts", "source_location": "L599"}, {"caller_nid": "usage_render_details_rendertimeseriescompact", "callee": "html", "source_file": "Agent Team version3\\control-ui\\src\\ui\\views\\usage-render-details.ts", "source_location": "L675"}, {"caller_nid": "usage_render_details_rendertimeseriescompact", "callee": "toLocaleTimeString", "source_file": "Agent Team version3\\control-ui\\src\\ui\\views\\usage-render-details.ts", "source_location": "L677"}, {"caller_nid": "usage_render_details_rendertimeseriescompact", "callee": "toLocaleTimeString", "source_file": "Agent Team version3\\control-ui\\src\\ui\\views\\usage-render-details.ts", "source_location": "L677"}, {"caller_nid": "usage_render_details_rendertimeseriescompact", "callee": "formatTokens", "source_file": "Agent Team version3\\control-ui\\src\\ui\\views\\usage-render-details.ts", "source_location": "L678"}, {"caller_nid": "usage_render_details_rendertimeseriescompact", "callee": "formatCost", "source_file": "Agent Team version3\\control-ui\\src\\ui\\views\\usage-render-details.ts", "source_location": "L679"}, {"caller_nid": "usage_render_details_rendertimeseriescompact", "callee": "reduce", "source_file": "Agent Team version3\\control-ui\\src\\ui\\views\\usage-render-details.ts", "source_location": "L679"}, {"caller_nid": "usage_render_details_rendertimeseriescompact", "callee": "html", "source_file": "Agent Team version3\\control-ui\\src\\ui\\views\\usage-render-details.ts", "source_location": "L681"}, {"caller_nid": "usage_render_details_rendertimeseriescompact", "callee": "formatTokens", "source_file": "Agent Team version3\\control-ui\\src\\ui\\views\\usage-render-details.ts", "source_location": "L681"}, {"caller_nid": "usage_render_details_rendertimeseriescompact", "callee": "formatCost", "source_file": "Agent Team version3\\control-ui\\src\\ui\\views\\usage-rende