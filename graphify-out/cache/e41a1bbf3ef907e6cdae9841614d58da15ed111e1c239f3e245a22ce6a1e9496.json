d": "model_catalog_applyopenaicodexsparkfallback", "callee": "some", "source_file": "Agent Team version3\\backend\\tools\\inventory\\lib\\agents\\model-catalog.ts", "source_location": "L35"}, {"caller_nid": "model_catalog_applyopenaicodexsparkfallback", "callee": "find", "source_file": "Agent Team version3\\backend\\tools\\inventory\\lib\\agents\\model-catalog.ts", "source_location": "L44"}, {"caller_nid": "model_catalog_applyopenaicodexsparkfallback", "callee": "push", "source_file": "Agent Team version3\\backend\\tools\\inventory\\lib\\agents\\model-catalog.ts", "source_location": "L52"}, {"caller_nid": "model_catalog_createauthstorage", "callee": "create", "source_file": "Agent Team version3\\backend\\tools\\inventory\\lib\\agents\\model-catalog.ts", "source_location": "L73"}, {"caller_nid": "model_catalog_loadmodelcatalog", "callee": "(async () => {\n    const models: ModelCatalogEntry[] = [];\n    const sortModels = (entries: ModelCatalogEntry[]) =>\n      entries.sort((a, b) => {\n        const p = a.provider.localeCompare(b.provider);\n        if (p !== 0) {\n          return p;\n        }\n        return a.name.localeCompare(b.name);\n      });\n    try {\n      const cfg = params?.config ?? loadConfig();\n      await ensureOpenClawModelsJson(cfg);\n      await (\n        await import(\"./pi-auth-json.js\")\n      ).ensurePiAuthJsonFromAuthProfiles(resolveOpenClawAgentDir());\n      // IMPORTANT: keep the dynamic import *inside* the try/catch.\n      // If this fails once (e.g. during a pnpm install that temporarily swaps node_modules),\n      // we must not poison the cache with a rejected promise (otherwise all channel handlers\n      // will keep failing until restart).\n      const piSdk = await importPiSdk();\n      const agentDir = resolveOpenClawAgentDir();\n      const { join } = await import(\"node:path\");\n      const authStorage = createAuthStorage(piSdk.AuthStorage, join(agentDir, \"auth.json\"));\n      const registry = new (piSdk.ModelRegistry as unknown as {\n        new (\n          authStorage: unknown,\n          modelsFile: string,\n        ):\n          | Array<DiscoveredModel>\n          | {\n              getAll: () => Array<DiscoveredModel>;\n            };\n      })(authStorage, join(agentDir, \"models.json\"));\n      const entries = Array.isArray(registry) ? registry : registry.getAll();\n      for (const entry of entries) {\n        const id = String(entry?.id ?? \"\").trim();\n        if (!id) {\n          continue;\n        }\n        const provider = String(entry?.provider ?? \"\").trim();\n        if (!provider) {\n          continue;\n        }\n        const name = String(entry?.name ?? id).trim() || id;\n        const contextWindow =\n          typeof entry?.contextWindow === \"number\" && entry.contextWindow > 0\n            ? entry.contextWindow\n            : undefined;\n        const reasoning = typeof entry?.reasoning === \"boolean\" ? entry.reasoning : undefined;\n        const input = Array.isArray(entry?.input) ? entry.input : undefined;\n        models.push({ id, name, provider, contextWindow, reasoning, input });\n      }\n      applyOpenAICodexSparkFallback(models);\n\n      if (models.length === 0) {\n        // If we found nothing, don't cache this result so we can try again.\n        modelCatalogPromise = null;\n      }\n\n      return sortModels(models);\n    } catch (error) {\n      if (!hasLoggedModelCatalogError) {\n        hasLoggedModelCatalogError = true;\n        console.warn(`[model-catalog] Failed to load model catalog: ${String(error)}`);\n      }\n      // Don't poison the cache on transient dependency/filesystem issues.\n      modelCatalogPromise = null;\n      if (models.length > 0) {\n        return sortModels(models);\n      }\n      return [];\n    }\n  })", "source_file": "Agent Team version3\\backend\\tools\\inventory\\lib\\agents\\model-catalog.ts", "source_location": "L89"}, {"caller_nid": "model_catalog_modelsupportsvision", "callee": "includes", "source_file": "Agent Team version3\\backend\\tools\\inventory\\lib\\agents\\model-catalog.ts", "source_location": "L171"}, {"caller_nid": "model_catalog_findmodelincatalog", "callee": "trim", "source_file": "Agent Team version3\\backend\\tools\\inventory\\lib\\agents\\model-catalog.ts", "source_location": "L182"}, {"caller_nid": "model_catalog_findmodelincatalog", "callee": "toLowerCase", "source_file": "Agent Team version3\\backend\\tools\\inventory\\lib\\agents\\model-catalog.ts", "source_location": "L182"}, {"caller_nid": "model_catalog_findmodelincatalog", "callee": "trim", "source_file": "Agent Team version3\\backend\\tools\\inventory\\lib\\agents\\model-catalog.ts", "source_location": "L183"}, {"caller_nid": "model_catalog_findmodelincatalog", "callee": "toLowerCase", "source_file": "Agent Team version3\\backend\\tools\\inventory\\lib\\agents\\model-catalog.ts", "source_location": "L183"}, {"caller_nid": "model_catalog_findmodelincatalog", "callee": "find", "source_file": "Agent Team version3\\backend\\tools\\inventory\\lib\\agents\\model-catalog.ts", "source_location": "L184"}]}