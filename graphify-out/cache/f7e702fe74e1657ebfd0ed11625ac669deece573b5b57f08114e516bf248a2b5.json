rce_file": "Agent Team version3\\backend\\tools\\inventory\\lib\\commands\\status-all\\channels.ts", "source_location": "L365"}, {"caller_nid": "channels_buildchannelstable", "callee": "collectStatusIssues", "source_file": "Agent Team version3\\backend\\tools\\inventory\\lib\\commands\\status-all\\channels.ts", "source_location": "L384"}, {"caller_nid": "channels_buildchannelstable", "callee": "map", "source_file": "Agent Team version3\\backend\\tools\\inventory\\lib\\commands\\status-all\\channels.ts", "source_location": "L384"}, {"caller_nid": "channels_buildchannelstable", "callee": "(() => {\n      if (!anyEnabled) {\n        return \"off\";\n      }\n      if (missingPaths.length > 0) {\n        return \"warn\";\n      }\n      if (issues.length > 0) {\n        return \"warn\";\n      }\n      if (link.linked === false) {\n        return \"setup\";\n      }\n      if (tokenSummary.state) {\n        return tokenSummary.state;\n      }\n      if (link.linked === true) {\n        return \"ok\";\n      }\n      if (configuredAccounts.length > 0) {\n        return \"ok\";\n      }\n      return \"setup\";\n    })", "source_file": "Agent Team version3\\backend\\tools\\inventory\\lib\\commands\\status-all\\channels.ts", "source_location": "L389"}, {"caller_nid": "channels_buildchannelstable", "callee": "(() => {\n      if (!anyEnabled) {\n        if (!defaultEntry) {\n          return \"disabled\";\n        }\n        return plugin.config.disabledReason?.(defaultEntry.account, cfg) ?? \"disabled\";\n      }\n      if (missingPaths.length > 0) {\n        return `missing file (${missingPaths[0]})`;\n      }\n      if (issues.length > 0) {\n        return issues[0]?.message ?? \"misconfigured\";\n      }\n\n      if (link.linked !== null) {\n        const base = link.linked ? \"linked\" : \"not linked\";\n        const extra: string[] = [];\n        if (link.linked && link.selfE164) {\n          extra.push(link.selfE164);\n        }\n        if (link.linked && link.authAgeMs != null && link.authAgeMs >= 0) {\n          extra.push(`auth ${formatTimeAgo(link.authAgeMs)}`);\n        }\n        if (accounts.length > 1 || plugin.meta.forceAccountBinding) {\n          extra.push(`accounts ${accounts.length || 1}`);\n        }\n        return extra.length > 0 ? `${base} \u00b7 ${extra.join(\" \u00b7 \")}` : base;\n      }\n\n      if (tokenSummary.detail) {\n        return tokenSummary.detail;\n      }\n\n      if (configuredAccounts.length > 0) {\n        const head = \"configured\";\n        if (accounts.length <= 1 && !plugin.meta.forceAccountBinding) {\n          return head;\n        }\n        return `${head} \u00b7 accounts ${configuredAccounts.length}/${enabledAccounts.length || 1}`;\n      }\n\n      const reason =\n        defaultEntry && plugin.config.unconfiguredReason\n          ? plugin.config.unconfiguredReason(defaultEntry.account, cfg)\n          : null;\n      return reason ?? \"not configured\";\n    })", "source_file": "Agent Team version3\\backend\\tools\\inventory\\lib\\commands\\status-all\\channels.ts", "source_location": "L414"}, {"caller_nid": "channels_buildchannelstable", "callee": "push", "source_file": "Agent Team version3\\backend\\tools\\inventory\\lib\\commands\\status-all\\channels.ts", "source_location": "L462"}, {"caller_nid": "channels_buildchannelstable", "callee": "push", "source_file": "Agent Team version3\\backend\\tools\\inventory\\lib\\commands\\status-all\\channels.ts", "source_location": "L471"}, {"caller_nid": "channels_buildchannelstable", "callee": "map", "source_file": "Agent Team version3\\backend\\tools\\inventory\\lib\\commands\\status-all\\channels.ts", "source_location": "L474"}]}