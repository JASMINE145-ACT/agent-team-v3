# ================================
# Agent Team v3 配置模板
# 复制此文件为 .env 并填入实际值
# ================================

# -------------------- LLM 配置 --------------------
# 主模型配置（必填）
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
LLM_MODEL=gpt-4o

# 智谱 AI 配置（可选，用于 GLM 系列模型）
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# ZHIPU_API_KEY=your-zhipu-key
# OPENAI_MODEL=glm-4.5-air
# LLM_MODEL=glm-4.5-air

# 备用模型（超时/失败时 fallback）
FALLBACK_BASE_URL=https://api.openai.com/v1
FALLBACK_API_KEY=your-fallback-key
FALLBACK_MODEL=gpt-4o-mini

# 摘要生成专用模型（可选，用于长文本压缩）
SUMMARY_LLM_MODEL=gpt-4o-mini
SUMMARY_LLM_BASE_URL=https://api.openai.com/v1
SUMMARY_LLM_API_KEY=your-summary-key

# 视觉模型（用于图片理解/OCR）
VISION_LLM_MODEL=gpt-4o
VISION_LLM_API_KEY=your-vision-key
VISION_LLM_BASE_URL=https://api.openai.com/v1

# -------------------- LLM 行为控制 --------------------
# 单次生成最大 token 数（默认 40000）
LLM_MAX_TOKENS=40000

# ReAct 循环最大步数（默认 12）
REACT_MAX_STEPS=12

# 是否使用 Claude Loop 三段式 prompt（默认 true）
USE_CLAUDE_LOOP_PROMPT=true

# -------------------- 工具返回与上下文限制 --------------------
# 普通工具单次返回最大字符数（默认 16000）
TOOL_RESULT_MAX_CHARS=16000

# Excel 工具单次返回最大字符数（默认 100000）
TOOL_RESULT_EXCEL_MAX_CHARS=100000

# 多轮对话总上下文上限（默认 16000）
CONTEXT_MAX_CHARS=16000

# -------------------- 会话管理 --------------------
# 单会话最大轮数（默认 20）
SESSION_MAX_TURNS=20

# 每次注入 prompt 的最近轮数（默认 4）
SESSION_INJECT_TURNS=4

# 注入时单条回答的截断上限（默认 2000）
SESSION_INJECT_ANSWER_TRIM=2000

# 会话持久化时单条回答的截断上限（默认 2000）
SESSION_ANSWER_TRIM=2000

# -------------------- 图片与 OCR --------------------
# 单张图片最大尺寸（MB，默认 5）
MAX_IMAGE_SIZE_MB=5

# 单次 OCR 最多处理图片数（默认 3）
MAX_OCR_IMAGES_PER_REQUEST=3

# OCR 提取文本最大字符数（默认 6000）
MAX_OCR_TEXT_CHARS=6000

# -------------------- 文件上传 --------------------
# 通用上传文件大小上限（MB，默认 200）
MAX_UPLOAD_MB=200

# -------------------- 库存与报价批量限制 --------------------
# 批量利润率查询单次最多处理条数（默认 50）
BATCH_PROFIT_MAX_ITEMS=50

# 批量库存查询单次最多接收 code 数（默认 50）
MAX_CODES_PER_BATCH=50

# search_inventory 返回 code 数上限（默认 10）
MAX_CODES_PER_SEARCH=10

# search_inventory 返回明细行数上限（默认 10）
MAX_DETAILS_FOR_AGENT=10

# -------------------- 报价单规格提取 --------------------
# 是否使用 LLM 批量提取规格（默认 true）
QUOTATION_SPEC_LLM=true

# -------------------- 补货确认行为 --------------------
# 补货确认是否真实写库存（默认 false=仅占位）
# true=调用 modify_inventory 写 ACCURATE，false=仅更新补货单状态
REPLENISHMENT_CONFIRM_REAL_INVENTORY=false

# -------------------- 数据库配置 --------------------
# Neon Postgres（无货/缺货/补货等数据）
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Accurate Online（万鼎 ERP API）
AOL_SIGNATURE_SECRET=your-signature-secret
AOL_ACCESS_TOKEN=your-access-token
AOL_DATABASE_ID=iris

# -------------------- 企业微信 --------------------
# 企业微信 URL 回调配置
WECOM_TOKEN=your-wecom-token
WECOM_AES_KEY=your-aes-key
WECOM_CORP_ID=your-corp-id
WECOM_AGENT_ID=your-agent-id

# 企业微信长连接 Bot
WECOM_BOT_ID=your-bot-id
WECOM_BOT_SECRET=your-bot-secret
# 访问企业微信接口（含文件下载）时的 HTTP 代理；海外部署若遇文件下载 ConnectTimeout 可配置
# WECOM_BOT_PROXY_URL=http://127.0.0.1:7890
# 文件下载整体超时（秒），默认 60；海外或弱网可适当调大
# WECOM_FILE_DOWNLOAD_TIMEOUT=60

# 企业微信 Excel 完整解析开关（默认 false）
WECHAT_EXCEL_FULL_PARSE_ENABLED=false

# -------------------- 开发/调试 --------------------
# 跳过 API 可用性检查（开发用，默认 1=跳过）
SKIP_API_CHECK=1

# 跳过所有 Preflight 检查（默认 1=跳过）
SKIP_PREFLIGHT=1

# -------------------- 第三方服务（可选） --------------------
# Langchain 追踪
LANGCHAIN_API_KEY=your-langchain-key
LANGCHAIN_PROJECT=your-project
LANGCHAIN_TRACING_V2=true

# ZEP 记忆服务
ZEP_API_KEY=your-zep-key

# Anthropic（如需使用 Claude）
ANTHROPIC_API_KEY=your-anthropic-key

# Google Maps/API（如需地理位置服务）
GOOGLE_MAPS_API_KEY=your-google-key
GOOGLE_API_KEY=your-google-key
