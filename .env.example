# ================================
# Agent Team v3 配置模板
# 复制此文件为 .env 并填入实际值
# ================================

# -------------------- LLM：主链路 + fallback + 其它角色 --------------------
#
# 【推荐】主 Agent = MiniMax（Anthropic Messages）+ 失败时 fallback 智谱 GLM（OpenAI 兼容 chat.completions）
#
# 主链路（CoreAgent / ReAct）— 必须同时设置以下四项：
PRIMARY_LLM_PROTOCOL=anthropic
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_API_KEY=your-minimax-key-with-anthropic-api-enabled
LLM_MODEL=MiniMax-M2.7
#
# MiniMax OpenAI 兼容 /v1（库存选型 llm_selector、或未走 anthropic 时的回退）：与主链路密钥通常同源
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_API_KEY=your-minimax-key
#
# 智谱 — OPENAI_BASE_URL 供非主链路、以及「智谱 URL + MiniMax 模型名」时的运行时改名回退；主模型超时/断连走 FALLBACK_*
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
OPENAI_BASE_URL_ZHIPU=https://open.bigmodel.cn/api/paas/v4
ZHIPU_API_KEY=your-zhipu-key
OPENAI_API_KEY=your-zhipu-key
OPENAI_MODEL=glm-4.5-air
FALLBACK_BASE_URL=https://open.bigmodel.cn/api/paas/v4
FALLBACK_API_KEY=your-zhipu-key
FALLBACK_MODEL=glm-4.5-air
#
# 备选：全程不走 Anthropic、只用智谱主对话 —— 设 PRIMARY_LLM_PROTOCOL=openai，且 LLM_MODEL=glm-4.5-air（勿在智谱端点填 MiniMax 模型名，否则会 1211）
GLM_OCR_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_OCR_API_KEY=your-zhipu-key
GLM_OCR_MODEL=glm-ocr

# 3) OpenAI — 仅记忆 / 上下文压缩（SUMMARY_LLM_*）
SUMMARY_LLM_MODEL=gpt-4o-mini
SUMMARY_LLM_BASE_URL=https://api.openai.com/v1
SUMMARY_LLM_API_KEY=your-openai-key

# 向量检索（Embeddings 如 text-embedding-3-large）非 chat；见 INVENTORY_OPENAI_EMBEDDING_MODEL

# 备选：全程智谱主对话（不用 MiniMax 时设 OPENAI_BASE_URL=智谱 URL + LLM_MODEL=glm-4.5-air）

# -------------------- LLM 行为控制 --------------------
LLM_MAX_TOKENS=40000
REACT_MAX_STEPS=12
USE_CLAUDE_LOOP_PROMPT=true
USE_DECISION_RULE_SKILLS=true

# -------------------- 工具返回与上下文限制 --------------------
TOOL_RESULT_MAX_CHARS=16000
TOOL_RESULT_EXCEL_MAX_CHARS=100000
CONTEXT_MAX_CHARS=16000

# -------------------- 会话管理 --------------------
SESSION_MAX_TURNS=20
SESSION_INJECT_TURNS=4
SESSION_INJECT_ANSWER_TRIM=2000
SESSION_ANSWER_TRIM=2000

# -------------------- 图片与 OCR --------------------
MAX_IMAGE_SIZE_MB=5
MAX_OCR_IMAGES_PER_REQUEST=3
MAX_OCR_TEXT_CHARS=6000

# -------------------- 文件上传 --------------------
MAX_UPLOAD_MB=200

# -------------------- 库存与报价批量限制 --------------------
BATCH_PROFIT_MAX_ITEMS=50
MAX_CODES_PER_BATCH=50
MAX_CODES_PER_SEARCH=10
MAX_DETAILS_FOR_AGENT=10
# 万鼎多候选选型（llm_selector）：INVENTORY_LLM_MODEL 或 LLM_MODEL 含 MiniMax 时自动走 MINIMAX_BASE_URL + MINIMAX_API_KEY，避免误用智谱 URL 导致 1211「模型不存在」
# 可选显式覆盖：INVENTORY_LLM_BASE_URL=  INVENTORY_LLM_API_KEY=  INVENTORY_LLM_MODEL=

# -------------------- 报价单规格提取 --------------------
QUOTATION_SPEC_LLM=true

# -------------------- 补货确认行为 --------------------
REPLENISHMENT_CONFIRM_REAL_INVENTORY=false

# -------------------- 数据库配置 --------------------
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
AOL_SIGNATURE_SECRET=your-signature-secret
AOL_ACCESS_TOKEN=your-access-token
AOL_DATABASE_ID=iris

# -------------------- 企业微信 --------------------
WECOM_TOKEN=your-wecom-token
WECOM_AES_KEY=your-aes-key
WECOM_CORP_ID=your-corp-id
WECOM_AGENT_ID=your-agent-id
WECOM_BOT_ID=your-bot-id
WECOM_BOT_SECRET=your-bot-secret
WECHAT_EXCEL_FULL_PARSE_ENABLED=false

# -------------------- 开发/调试 --------------------
SKIP_API_CHECK=1
SKIP_PREFLIGHT=1

# -------------------- 第三方服务（可选）--------------------
LANGCHAIN_API_KEY=your-langchain-key
LANGCHAIN_PROJECT=your-project
LANGCHAIN_TRACING_V2=true
ZEP_API_KEY=your-zep-key
ANTHROPIC_API_KEY=your-anthropic-key
GOOGLE_MAPS_API_KEY=your-google-key
GOOGLE_API_KEY=your-google-key
