# 企业微信应用消息 API（用于 /agent/notify）
WECOM_CORP_ID=wwxxxx
WECOM_APP_SECRET=your-app-secret
WECOM_APP_AGENT_ID=1000001

# 可选：请求超时（秒，默认 10）
WECOM_APP_TIMEOUT_SEC=10

# 可选：群别名到用户列表映射（用于 to_parties 别名扩展）
# 格式：alias:user1|user2,alias2:user3|user4
WECOM_GROUP_ALIAS_MAPPING=alerts_group:zhangsan|lisi,inventory_team:wangwu|zhao
