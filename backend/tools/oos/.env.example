# =============================================================================
# 报价单无货产品追踪系统 - 环境变量示例
# 复制为 .env 并填入真实值，勿提交 .env 到版本库
# =============================================================================

# -----------------------------------------------------------------------------
# 必填：LLM（OpenAI）- 用于无货行字段匹配
# 获取 API Key: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=              # 必填

# -----------------------------------------------------------------------------
# 可选：LLM 参数
# -----------------------------------------------------------------------------
# LLM_MODEL=gpt-4o-mini
# LLM_MAX_TOKENS=5000
# LLM_TEMPERATURE=0.0
# LLM_PARSE_MAX_RETRIES=2

# -----------------------------------------------------------------------------
# 可选：无货识别模式（默认 false = LLM 全量读整段数据表；true = 先规则锁定无货再送上下文）
# -----------------------------------------------------------------------------
# USE_WUHOU_CONTEXT_MODE=false
# WUHOU_CONTEXT_ROWS=2

# -----------------------------------------------------------------------------
# 可选：数据库
# -----------------------------------------------------------------------------
# 开发环境默认 SQLite，无需配置
# QUOTATION_DB_PATH=data/out_of_stock.db

# 生产环境使用 PostgreSQL 时填写
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# -----------------------------------------------------------------------------
# 可选：文件上传
# -----------------------------------------------------------------------------
# UPLOAD_DIR=uploads

# -----------------------------------------------------------------------------
# 可选：无货/缺货提醒（第二次被报无货或缺货时发提醒；发完打时间戳，见 doc/oos-email-wecom-alerts.md）
# -----------------------------------------------------------------------------
# 通道：email_only（默认）| wecom_only | both
# OOS_ALERT_MODE=email_only

# EMAIL_RECIPIENTS=user1@example.com,user2@example.com
# EMAIL_COOLDOWN_HOURS=24

# 企业微信群机器人（需在企业微信群内添加机器人并复制 Webhook）
# WECOM_GROUP_ALERT_ENABLED=true
# WECOM_GROUP_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxx
# WECOM_GROUP_MENTIONED_MOBILE_LIST=13800138000
# WECOM_GROUP_MENTIONED_USERIDS=userid1,@all

# 企业微信应用消息 API（通过 /agent/notify 发送，优先于 Webhook）
# corp_id / app_secret / agent_id 来自企业微信自建应用
# WECOM_APP_NOTIFY_USERS=jiacheng,jasmine  # 收件人 userid，逗号分隔

# Gmail 示例（必须用「应用专用密码」App Password，不是登录密码）
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_FROM=your@gmail.com
# EMAIL_USERNAME=your@gmail.com
# EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# QQ 邮箱示例
# EMAIL_SMTP_HOST=smtp.qq.com
# EMAIL_SMTP_PORT=587
# EMAIL_FROM=your@qq.com
# EMAIL_USERNAME=your@qq.com
# EMAIL_PASSWORD=QQ邮箱SMTP授权码
